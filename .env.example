# Neon Postgres (pooled connection string from Neon Console)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# Neon Auth (from Neon Console → Auth → Configuration)
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=generate-with-openssl-rand-base64-32

# Force in-memory mode even when DATABASE_URL is set (local dev only)
# USE_MEMORY_DB=true
